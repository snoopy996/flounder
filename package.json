{
  "name": "flounders",
  "version": "0.2.0",
  "description": "Autonomous white-hat security auditor for AI-driven code review, exploit construction, and execution-grounded verification.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adshao/flounder.git"
  },
  "bugs": {
    "url": "https://github.com/adshao/flounder/issues"
  },
  "homepage": "https://github.com/adshao/flounder#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pi/extension": {
      "types": "./dist/pi/extension.d.ts",
      "import": "./dist/pi/extension.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "flounder": "./dist/cli.js"
  },
  "engines": {
    "node": ">=24.13 <25"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "npm run check:ui && vite build --config src/server/ui/vite.config.ts",
    "check": "tsc -p tsconfig.json --noEmit && npm run check:ui",
    "check:ui": "tsc -p src/server/ui/tsconfig.json --noEmit",
    "dev:ui": "vite --config src/server/ui/vite.config.ts",
    "test": "npm run build && node --test tests/*.test.mjs",
    "check:api-catalog": "npm run build && npm run check:api-catalog:dist",
    "check:api-catalog:dist": "node scripts/check-api-catalog.mjs",
    "check:public": "node scripts/check-public-surface.mjs",
    "check:public:commit": "node scripts/check-public-surface.mjs --head-only",
    "hooks:install": "git config core.hooksPath .githooks",
    "verify": "npm run check && npm test && npm run check:api-catalog:dist && npm run mock-audit && npm run check:public",
    "sandbox:build": "docker build -f docker/flounder-sandbox.Dockerfile -t flounder-sandbox:latest .",
    "sandbox:cairo:build": "docker build -f docker/flounder-sandbox-cairo.Dockerfile -t flounder-sandbox:cairo .",
    "sandbox:cairo:target": "node scripts/cairo-sandbox-image.mjs",
    "sandbox:ton:build": "docker build -f docker/flounder-sandbox-ton.Dockerfile -t flounder-sandbox:ton .",
    "prepack": "npm run build",
    "start": "node ./dist/cli.js",
    "mock-audit": "node scripts/mock-audit.mjs"
  },
  "keywords": [
    "pi-package",
    "security-audit",
    "white-hat",
    "agent",
    "ai-agent",
    "autonomous-audit",
    "vulnerability-research",
    "code-audit",
    "solidity",
    "smart-contract",
    "zk",
    "zero-knowledge",
    "sandbox",
    "codex",
    "claude-code"
  ],
  "files": [
    "dist/agent/**",
    "dist/agents/**",
    "dist/db/**",
    "dist/ingest/**",
    "dist/lens/**",
    "dist/llm/**",
    "dist/pi/**",
    "dist/reports/**",
    "dist/security/**",
    "dist/server/**",
    "dist/trace/**",
    "dist/util/**",
    "dist/cli.*",
    "dist/config.*",
    "dist/index.*",
    "dist/types.*",
    "src/**",
    "skills/**",
    "prompts/**",
    "configs/**",
    "docker/**",
    "docs/**",
    "fixtures/**",
    "assets/screenshots/demo-full-overview.png",
    "scripts/**",
    "README.md",
    "AGENTS.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/pi/extension.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.80.2",
    "@earendil-works/pi-coding-agent": "0.80.2",
    "@types/node": "^24.13.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typebox": "1.2.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
