{
  "name": "flounder-scanner",
  "version": "0.1.0",
  "description": "Flounder — find vulnerabilities beneath the surface. A white-hat agentic security auditor built on pi-mono primitives.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pi/extension": {
      "types": "./dist/pi/extension.d.ts",
      "import": "./dist/pi/extension.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "flounder": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "check:public": "node scripts/check-public-surface.mjs",
    "verify": "npm run check && npm test && npm run mock-audit && npm run check:public",
    "prepack": "npm run build",
    "start": "node ./dist/cli.js",
    "mock-audit": "node ./dist/cli.js run --quick --target mock-audit --source ./fixtures --mock-llm --max-steps 10 --out runs"
  },
  "keywords": [
    "pi-package",
    "security-audit",
    "whitehat",
    "agent",
    "solidity",
    "smart-contract",
    "evm",
    "defi",
    "zk",
    "crypto"
  ],
  "files": [
    "dist/agent/**",
    "dist/agents/**",
    "dist/db/**",
    "dist/ingest/**",
    "dist/lens/**",
    "dist/llm/**",
    "dist/pi/**",
    "dist/reports/**",
    "dist/security/**",
    "dist/server/**",
    "dist/trace/**",
    "dist/util/**",
    "dist/cli.*",
    "dist/config.*",
    "dist/index.*",
    "dist/types.*",
    "src/**",
    "skills/**",
    "prompts/**",
    "configs/**",
    "docs/**",
    "fixtures/**",
    "scripts/**",
    "README.md",
    "AGENTS.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/pi/extension.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.78.1",
    "@earendil-works/pi-coding-agent": "0.78.1",
    "@types/node": "^24.0.0",
    "typebox": "1.2.0",
    "typescript": "^5.9.0"
  }
}
